{
  "name": "backend",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "dev": "tsx watch src/main.ts",
    "format": "prettier --write --cache --cache-location node_modules/.cache/prettier/.prettier-cache src/",
    "lint": "eslint . --fix --cache --cache-location node_modules/.cache/eslint/.eslintcache",
    "type-check": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:deploy": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "db:seed": "node dist/prisma/seed.js"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "jiti": "^2.6.1",
    "prettier": "^3.8.1",
    "prisma": "^7.7.0",
    "tsx": "^4.19.2",
    "typescript": "^6.0.2",
    "typescript-eslint": "^8.58.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@prisma/client": "^7.7.0",
    "fastify": "^5.8.4",
    "socket.io": "^4.8.1",
    "zod": "^4.3.6"
  }
}
